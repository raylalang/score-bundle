    {"id":"n1","type":"text","x":965,"y":370,"width":230,"height":18,"angle":0,"strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":80,"versionNonce":80,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"prior × likelihood → approximate posterior","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"prior × likelihood → approximate posterior","lineHeight":1.25,"baseline":11},
    {"id":"note","type":"text","x":60,"y":700,"width":1450,"height":56,"angle":0,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":81,"versionNonce":81,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"Across all three phases only the LIKELIHOOD changes: per-note Gaussian on exact targets (Ph 1) → per-note Gaussian on f₀-derived targets (Ph 2) → one global audio likelihood (Ph 3).\nThe graph GP prior is reused unchanged. What is lost in Phase 3 is conjugacy, not structure: the amplitudes a stay conditionally Gaussian and marginalise exactly, so only the\nnonlinear positions z need approximation. This is the most novel stage, and it is not yet started.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Across all three phases only the LIKELIHOOD changes: per-note Gaussian on exact targets (Ph 1) → per-note Gaussian on f₀-derived targets (Ph 2) → one global audio likelihood (Ph 3).\nThe graph GP prior is reused unchanged. What is lost in Phase 3 is conjugacy, not structure: the amplitudes a stay conditionally Gaussian and marginalise exactly, so only the\nnonlinear positions z need approximation. This is the most novel stage, and it is not yet started.","lineHeight":1.25,"baseline":11}
