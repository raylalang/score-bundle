    {"id":"prior_t","type":"text","x":375,"y":185,"width":300,"height":125,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":31,"versionNonce":31,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"PRIOR  p(z)  —  UNCHANGED\nthe same multi-output graph GP\n\nK = B ⊗ K_G(s)\n  + Σ diag(c_f) ⊗ X_f X_fᵀ\n\nz = tempo, τ, intonation c, vibrato\n(nonlinear position variables)","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","containerId":"prior","originalText":"PRIOR  p(z)  —  UNCHANGED\nthe same multi-output graph GP\n\nK = B ⊗ K_G(s)\n  + Σ diag(c_f) ⊗ X_f X_fᵀ\n\nz = tempo, τ, intonation c, vibrato\n(nonlinear position variables)","lineHeight":1.25,"baseline":11},

