    {"id":"t2","type":"text","x":60,"y":70,"width":1050,"height":22,"angle":0,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":12,"versionNonce":12,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"Given only the score and the raw audio. No per-note targets exist — every note's expression is latent. Conjugacy is lost; the prior is unchanged.","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Given only the score and the raw audio. No per-note targets exist — every note's expression is latent. Conjugacy is lost; the prior is unchanged.","lineHeight":1.25,"baseline":16},

