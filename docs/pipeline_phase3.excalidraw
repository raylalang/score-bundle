    {"id":"lik","type":"rectangle","x":760,"y":430,"width":390,"height":175,"angle":0,"strokeColor":"#e03131","backgroundColor":"#ffc9c9","fillStyle":"solid","strokeWidth":3,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":40,"versionNonce":40,"isDeleted":false,"boundElements":[{"type":"text","id":"lik_t"}],"updated":1,"link":null,"locked":false},
    {"id":"lik_t","type":"text","x":775,"y":455,"width":360,"height":125,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":41,"versionNonce":41,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"LIKELIHOOD — the whole change\n\nx = Φ(z) a + ε,   ε ~ N(0, Kₙ)\n\namplitudes collapse analytically:\np(x | z) = N(x; Φμₐ, ΦΣₐΦᵀ + Kₙ)\n\nONE global audio likelihood —\nno per-note observations at all","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","containerId":"lik","originalText":"LIKELIHOOD — the whole change\n\nx = Φ(z) a + ε,   ε ~ N(0, Kₙ)\n\namplitudes collapse analytically:\np(x | z) = N(x; Φμₐ, ΦΣₐΦᵀ + Kₙ)\n\nONE global audio likelihood —\nno per-note observations at all","lineHeight":1.25,"baseline":11},

    {"id":"inf","type":"rectangle","x":760,"y":160,"width":390,"height":175,"angle":0,"strokeColor":"#e8590c","backgroundColor":"#ffd8a8","fillStyle":"solid","strokeWidth":3,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":42,"versionNonce":42,"isDeleted":false,"boundElements":[{"type":"text","id":"inf_t"}],"updated":1,"link":null,"locked":false},
    {"id":"inf_t","type":"text","x":775,"y":185,"width":360,"height":125,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":43,"versionNonce":43,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"INFERENCE — no longer closed form\n\nΦ(z) is nonlinear in z, so the\nposterior over z is approximated:\nLaplace  or  variational inference,\ninitialised from the nominal score\n(handles f₀ octave multimodality)\n\nthen p(a | x, z) recovered in closed form","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","containerId":"inf","originalText":"INFERENCE — no longer closed form\n\nΦ(z) is nonlinear in z, so the\nposterior over z is approximated:\nLaplace  or  variational inference,\ninitialised from the nominal score\n(handles f₀ octave multimodality)\n\nthen p(a | x, z) recovered in closed form","lineHeight":1.25,"baseline":11},

