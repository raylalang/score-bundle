    {"id":"synth_t","type":"text","x":375,"y":448,"width":300,"height":54,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":33,"versionNonce":33,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"Differentiable harmonic synthesizer\nΦ(z) : quadrature basis, phase\nφₖ(t) = 2πk ∫ f₀(s) ds  set by z","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","containerId":"synth","originalText":"Differentiable harmonic synthesizer\nΦ(z) : quadrature basis, phase\nφₖ(t) = 2πk ∫ f₀(s) ds  set by z","lineHeight":1.25,"baseline":11},

