    {"id":"kern_t","type":"text","x":745,"y":195,"width":340,"height":165,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":41,"versionNonce":41,"isDeleted":false,"boundElements":[],"updated":1,"link":null,"locked":false,"text":"THE SAME GP\n\nK = B ⊗ K_G(s)\n  + Σ diag(c_f) ⊗ X_f X_fᵀ\n  + diag(ς²) ⊗ I\n\nB grows: it now couples\nτ, log r, v, c, vibrato\n\nς² is no longer ≈ 0","fontSize":14,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","containerId":"kern","originalText":"THE SAME GP\n\nK = B ⊗ K_G(s)\n  + Σ diag(c_f) ⊗ X_f X_fᵀ\n  + diag(ς²) ⊗ I\n\nB grows: it now couples\nτ, log r, v, c, vibrato\n\nς² is no longer ≈ 0","lineHeight":1.25,"baseline":11},

