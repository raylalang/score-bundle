# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Data (do not commit datasets)
data/
*.wav
*.mid
*.midi

# Run artifacts (regenerable; do not commit)
/checkpoints/
/.cache/
/logs/
/figures/
!docs/thesis/figures/
*.pt
*.pkl
*.pdf
!docs/thesis/figures/*.pdf
*.zip

# LaTeX build artifacts (regenerable by pdflatex; do not commit)
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# OS
.DS_Store

# EXCEPTION (must stay last — later rules win): primary evidence behind the
# thesis claims (one-shot confirmation run + cited report logs). Deliberately
# committed against the regenerable-artifacts rule; see evidence/README.md.
!evidence/**/*.pkl
!evidence/**/*.log
